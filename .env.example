# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# URL where the Mini App is hosted (must be HTTPS)
WEBAPP_URL=https://your-domain.com

# Server port
PORT=3000

# Short name of the Mini App configured in @BotFather (/newapp command)
APP_SHORT_NAME=staff

# Google Gemini API Key (for AI message analysis)
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of Telegram User IDs for administrators
# Example: ADMIN_IDS=12345678,87654321
ADMIN_IDS=
